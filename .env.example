# For the committed/reported run you need NO keys: `npm run pipeline -- --dry-run`
# replays the frozen cache under data/raw and reproduces every number for free.
# The keys below are only needed for a cold run that re-hits the web + LLM.

COMPOSIO_API_KEY=       # dogfooded: COMPOSIO_SEARCH + Firecrawl toolkits, and the Notion demo
ANTHROPIC_API_KEY=      # Claude (extraction + critic)
FIRECRAWL_API_KEY=      # docs/pricing scraping
NOTION_TOKEN=           # live Notion toolkit demo only

# Optional: run Claude via AWS Bedrock instead of the Anthropic API
LLM_PROVIDER=           # set to "bedrock" to enable; leave empty for Anthropic direct
AWS_REGION=
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_SONNET=   # Bedrock model id mapped from claude-sonnet-5
BEDROCK_MODEL_OPUS=     # Bedrock model id mapped from claude-opus-4-8
